# 文本转语音：MiloraAPI mbAIscvip（默认）
# 文档: https://api.milorapart.top/docs/75/mbAIscvip
TTS_PROVIDER=milora
MILORA_TTS_API_KEY=your_api_key_here
# 可选：与文档一致的 query 参数名，一般为 key
# MILORA_TTS_API_KEY_PARAM=key
# MILORA_TTS_ENDPOINT=https://api.milorapart.top/apis/mbAIscvip
# MILORA_TTS_AUTH_MODE=query
# MILORA_TTS_TIMEOUT_MS=120000

# 兼容旧变量名（与 MILORA_* 二选一即可）
# MAMBO_TTS_API_KEY=your_api_key_here

# 无旁白
# TTS_PROVIDER=none

# 讯飞长文本 TTS（备用）
# TTS_PROVIDER=xfyun
# XFYUN_APP_ID=your_appid
# XFYUN_API_KEY=your_api_key
# XFYUN_API_SECRET=your_api_secret
# XFYUN_VCN=x4_mingge
# XFYUN_SPEED=50
# XFYUN_VOLUME=50
# XFYUN_PITCH=50
# XFYUN_SAMPLE_RATE=16000

PORT=3000
